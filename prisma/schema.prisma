generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Admin login accounts only. Created via the seed script, never by the
// public registration form.
model User {
  id           BigInt   @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("users")
}

// Public event registrations. Standalone — the registration form writes
// only here. No account / login is created.
model Registration {
  id          BigInt   @id @default(autoincrement())
  fullName    String?
  email       String   @unique
  whatsapp    String?  @unique
  institution String?
  grade       String?
  city        String?
  motivation  String?
  problem     String?
  createdAt   DateTime @default(now())

  @@map("registrations")
}

// Email captured from the landing-page pre-register form.
model Preregistration {
  id        BigInt   @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("preregistrations")
}

enum AnnouncementType {
  URGENT
  UPDATE
  EVENT
}

model Announcement {
  id        BigInt           @id @default(autoincrement())
  title     String
  content   String
  type      AnnouncementType @default(UPDATE)
  createdAt DateTime         @default(now())

  @@map("announcements")
}
